{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://brindarani.onrender.com/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://brindarani.onrender.com/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
